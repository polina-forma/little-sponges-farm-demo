# Little Sponges Spanish Tutor - Environment Variables
# Copy this file to .env.local and fill in your API keys

# =============================================================================
# AI PROVIDER (choose one)
# =============================================================================

# Options: "claude" or "openai"
AI_PROVIDER=claude

# Anthropic API Key (for Claude)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API Key (for GPT-4 and Whisper)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# =============================================================================
# TEXT-TO-SPEECH PROVIDER
# =============================================================================

# Options: "browser" (free), "elevenlabs" (best quality), "openai" (good quality)
VITE_TTS_PROVIDER=browser

# ElevenLabs API Key (optional, for premium TTS)
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=xxxxx

# ElevenLabs Voice ID (optional)
# Browse voices at: https://elevenlabs.io/voice-library
# Default is "Rachel" - a friendly female voice
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# =============================================================================
# DEPLOYMENT (Vercel)
# =============================================================================

# These are automatically set by Vercel, but you can override for local dev
# VERCEL_URL=localhost:3000
